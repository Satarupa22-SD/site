{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",

        "lib": [
            "ES2022",
            "DOM",
            "WebWorker"
        ],

        "strict": true,

        "isolatedModules": true,

        "verbatimModuleSyntax": true,

        "allowSyntheticDefaultImports": true,

        "esModuleInterop": true,

        "skipLibCheck": true,

        "noEmit": true
    },

    "include": [
        "assets/**/*.ts"
    ]
}
